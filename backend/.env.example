# ===========================================
# Backend Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# MongoDB Connection
MONGODB_URI=mongodb://username:password@host:port/database?authSource=admin

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Server Port
PORT=8080

# PromptPay (Payment) — fallback only, used if no owner has set it yet in admin Settings > PromptPay
PROMPTPAY_ID=your_promptpay_id

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8081

# Web Push (chat notifications) — generate once with `npx web-push generate-vapid-keys`.
# The private key is a one-way door: losing/rotating it invalidates every existing
# browser subscription. NEXT_PUBLIC_VAPID_PUBLIC_KEY in frontend/.env.local must be
# set to the same public key value.
WEB_PUSH_VAPID_PUBLIC_KEY=your_vapid_public_key
WEB_PUSH_VAPID_PRIVATE_KEY=your_vapid_private_key
WEB_PUSH_VAPID_SUBJECT=mailto:you@example.com
