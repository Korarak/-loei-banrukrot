client_secret*.json

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/
*/dist/
*/build/

# Docker
docker-compose.override.yml

# Test coverage
coverage/
.nyc_output/

# Deployment summaries and config
deployment_summary.md
.env.production
docker-compose.local.yml
test-local-prod.bat
create-local-admin.bat
docker-compose.dev.yml
test-local-dev.bat
create-dev-admin.bat

# Application Uploads
backend/public/uploads/
!backend/public/uploads/.gitkeep
