# ===========================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in the values
# Used by: docker-compose.yml (production)
# ===========================================

# Private Docker registry that holds the built backend/frontend images
# (self-hosted via the `registry` service in docker-compose.yml, fronted by NPM)
REGISTRY_URL=registry.banrukrot.com

# MongoDB root credentials
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=

# Shared JWT signing secret
JWT_SECRET=

# Public site URL — used for CORS allowlist and links in emails
FRONTEND_URL=https://banrukrot.com

# Public API URL used by the frontend browser bundle
NEXT_PUBLIC_API_URL=https://banrukrot.com/api

# Optional: Google OAuth for customer login (leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Web Push for chat notifications (leave blank to disable).
# Generate once with `npx web-push generate-vapid-keys` — the private key is a
# one-way door, losing/rotating it invalidates every existing subscription.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY must be the same value as WEB_PUSH_VAPID_PUBLIC_KEY
# below; it's baked into the frontend image at build time by the GitHub Actions
# workflow (see .github/workflows/deploy.yml build-args), not read here at deploy time.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=
