# ===========================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in the values
# Used by: docker-compose.yml / Portainer Stack
# ===========================================

# Domain / Server IP (without trailing slash)
# Examples:
#   Local dev:  http://localhost
#   Production: https://shop.example.com
APP_DOMAIN=http://localhost

# Ports
BACKEND_PORT=8080
FRONTEND_PORT=8081

# Public API URL (used by frontend browser-side requests)
# Usually: ${APP_DOMAIN}:${BACKEND_PORT}/api
NEXT_PUBLIC_API_URL=http://localhost:8080/api
